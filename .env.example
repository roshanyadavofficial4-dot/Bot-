# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# Exchange Credentials (Binance)
BINANCE_API_KEY="your_binance_api_key_here"
BINANCE_SECRET="your_binance_secret_here"

# Set to "true" for paper trading (testnet), "false" for live production
USE_SANDBOX="true"

# Starting capital in USDT (approx $2.4 = ₹200)
INITIAL_CAPITAL="2.4"

# Base asset (USDT recommended)
BASE_ASSET="USDT"

# Telegram Notifications
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"
# Your Telegram user ID for admin-only commands (/pause, /resume, /close_all)
TELEGRAM_ADMIN_ID="your_telegram_user_id_here"

# Gemini API Keys (Round-Robin Load Balancing)
GEMINI_API_KEY_1="gemini_key_01"
GEMINI_API_KEY_2="gemini_key_02"
GEMINI_API_KEY_3="gemini_key_03"
GEMINI_API_KEY_4="gemini_key_04"
GEMINI_API_KEY_5="gemini_key_05"
GEMINI_API_KEY_6="gemini_key_06"
GEMINI_API_KEY_7="gemini_key_07"
GEMINI_API_KEY_8="gemini_key_08"
GEMINI_API_KEY_9="gemini_key_09"
GEMINI_API_KEY_10="gemini_key_10"
